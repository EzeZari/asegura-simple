generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// --- ITERACIÓN 1: CORE (Gestión de Pólizas y Asegurados) ---

model Productor {
  id             Int      @id @default(autoincrement())
  nombre         String
  apellido       String
  email          String   @unique
  telefono       String?
  usuario        String   @unique
  contrasenaHash String
  fechaAlta      DateTime @default(now())

  // Conexión con el sistema de autenticación
  userId         Int?     @unique
  user           User?    @relation(fields: [userId], references: [id])

  asegurados         Asegurado[]
  companias          Compania[] 
  notasSiniestro     NotaSiniestro[]
  historialSiniestro HistorialSiniestro[]
  alertas            Alerta[]

  envioAutomaticoActivo  Boolean  @default(false)
  horaEnvioAutomatico    String   @default("09:00")
  diasAvisoAutomatico    Int      @default(15)

  actividades        Actividad[] 
}

model Asegurado {
  id              Int       @id @default(autoincrement())
  nombre          String    // Nombre o Razón Social
  apellido        String?   // Opcional por si es empresa
  tipo            String    @default("Individuo") 
  dni             String    // 🔥 ¡ACÁ ESTABA EL ERROR! BORRÁ EL @unique QUE TENÍAS AL LADO
  fechaNacimiento DateTime?
  condicionIva    String    @default("Consumidor Final")
  email           String?
  telefono        String?
  direccion       String?
  codigoPostal    String?
  activo          Boolean   @default(true)
  fechaRegistro   DateTime  @default(now())
  
  productorId     Int
  productor       Productor @relation(fields: [productorId], references: [id])

  polizas         Poliza[]

  @@unique([productorId, dni]) // Esta regla sí la dejás, está perfecta
}

model Compania {
  id                 Int      @id @default(autoincrement())
  nombre             String
  cuit               String?  // <-- Agregamos CUIT
  telefonoSiniestros String?  // <-- Agregamos Teléfono
  email              String?

  productorId        Int        // 🔥 ESTO FALTABA: Dueño de la compañía
  productor          Productor  @relation(fields: [productorId], references: [id]) // 🔥 ESTO FALTABA

  polizas            Poliza[]
}

model Poliza {
  id               Int      @id @default(autoincrement())
  nroPoliza        String   @unique
  tipoPoliza       String
  fechaInicio      DateTime
  fechaVencimiento DateTime
  estado           String
  cobertura        String?

  aseguradoId      Int
  asegurado        Asegurado @relation(fields: [aseguradoId], references: [id])
  
  companiaId       Int
  compania         Compania  @relation(fields: [companiaId], references: [id])

  siniestros       Siniestro[]
  alertas          Alerta[]

  // Datos específicos condicionales
  patente           String?
  marca             String?
  modelo            String?
  ubicacionRiesgo   String?
  cantidadEmpleados String?

  ultimoAviso DateTime?

  pdfUrl        String?
}

model Alerta {
  id              Int      @id @default(autoincrement())
  mensaje         String
  fechaGeneracion DateTime @default(now())
  
  polizaId        Int
  poliza          Poliza   @relation(fields: [polizaId], references: [id])

  productorId     Int
  productor       Productor @relation(fields: [productorId], references: [id])
}

// --- ITERACIÓN 2: GESTIÓN DE SINIESTROS ---

model Siniestro {
  id                 Int      @id @default(autoincrement())
  nroSiniestro       String   @unique
  fechaHecho         DateTime
  descripcionInicial String
  estadoSiniestro    String
  fechaCreacion      DateTime @default(now())
  fechaCierre        DateTime?

  polizaId           Int
  poliza             Poliza   @relation(fields: [polizaId], references: [id])

  notas          NotaSiniestro[]
  historial      HistorialSiniestro[]
  linksConsulta  LinkConsulta[]
  notificaciones Notificacion[]
}

model NotaSiniestro {
  id          Int      @id @default(autoincrement())
  texto       String
  fecha       DateTime @default(now())
  publico     Boolean  @default(false)

  siniestroId Int
  siniestro   Siniestro @relation(fields: [siniestroId], references: [id])
  
  productorId Int
  productor   Productor @relation(fields: [productorId], references: [id])
}

model HistorialSiniestro {
  id             Int      @id @default(autoincrement())
  estadoAnterior String
  estadoNuevo    String
  fechaCambio    DateTime @default(now())
  comentario     String?

  siniestroId    Int
  siniestro      Siniestro @relation(fields: [siniestroId], references: [id])
  
  productorId    Int
  productor      Productor @relation(fields: [productorId], references: [id])
}

model LinkConsulta {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  url         String?
  creadoEn    DateTime @default(now())
  expiracion  DateTime
  activo      Boolean  @default(true)

  siniestroId Int
  siniestro   Siniestro @relation(fields: [siniestroId], references: [id])
}

model Notificacion {
  id           Int      @id @default(autoincrement())
  canal        String
  destinatario String
  motivo       String
  mensaje      String
  enviadaEn    DateTime @default(now())
  estadoEnvio  String

  siniestroId  Int
  siniestro    Siniestro @relation(fields: [siniestroId], references: [id])
}

enum Role {
  ADMIN
  PRODUCTOR
  VIEWER
}

model User {
  id                   Int      @id @default(autoincrement())
  nombre               String
  email                String   @unique
  telefono             String
  password             String
  role                 Role     @default(PRODUCTOR) 
  createdAt            DateTime @default(now())

  resetPasswordToken   String?  
  resetPasswordExpires DateTime? 
  twoFactorEnabled     Boolean @default(false)

  codigoVerificacion   String?  // Acá guardamos el código de 6 dígitos
  emailPendiente       String?  // Acá guardamos el nuevo mail hasta que se verifique

  isVerified           Boolean  @default(false)
  verificationToken    String?  @unique

  // 🔥 NUEVOS CAMPOS RELACIONADOS CON PLANES Y MONETIZACIÓN
  plan                 Plan          @default(GRATUITO) // 🔥 Antes decía BASICO
  suscripcion          Suscripcion?
  productor            Productor?    // 🔥 NUEVO

  pagos         Pago[]
}

model Actividad {
  id          Int      @id @default(autoincrement())
  accion      String   
  entidad     String   
  descripcion String   
  cliente     String?
  fecha       DateTime @default(now())

  productorId Int?                                                    // ← AGREGAR
  productor   Productor? @relation(fields: [productorId], references: [id])  // ← AGREGAR
}

model Agencia {
  id                    Int      @id @default(1)
  nombre                String   @default("AseguraSimple")
  cuit                  String?
  email                 String?
  telefono              String?
  firma                 String?
  logoUrl               String?  
  mensajeVencimiento    String?  @db.Text
  mensajeBienvenida     String?  @db.Text
  diasAlertaVencimiento Int      @default(30)
  diasAlertaCritica     Int      @default(7)  

  // --- NUEVOS CAMPOS PARA AUTOMATIZACIÓN (CRON JOB) ---
  envioAutomaticoActivo Boolean  @default(false) // Apagado por defecto por seguridad
  horaEnvioAutomatico   String   @default("09:00") // Hora a la que el robot se despierta
  diasAvisoAutomatico   Int      @default(15) // Exactamente cuántos días antes manda el mail
  
  enviarMailBienvenida  Boolean  @default(true)

  updatedAt             DateTime @updatedAt
}

// 🔥 NUEVO: ENUM PARA CONTROL DE TRÁFICO Y LÍMITES EN EL SAAS
enum Plan {
  GRATUITO // 🔥 Nuevo plan inicial
  BASICO
  PROFESIONAL
  AGENCIA
}

// 🔥 NUEVO: MODELO DE SUSCRIPCIONES ASOCIADAS A MERCADO PAGO
model Suscripcion {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  mpPreapprovalId String?   @unique // ID de la suscripción recurrente (Plan mensual) en MP
  mpCustomerId    String?   // ID del comprador registrado dentro de MP
  estado          String    @default("pendiente") // pendiente, autorizado, en_proceso, cancelado
  
  fechaInicio      DateTime  @default(now())
  fechaVencimiento DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
// 🔥 NUEVA TABLA: Historial de Pagos
model Pago {
  id              Int      @id @default(autoincrement())
  userId          Int
  mpPagoId        String   @unique 
  monto           Float
  moneda          String   @default("ARS")
  estado          String   // 'approved', 'rejected', etc.
  metodoPago      String?  // 'credit_card', 'account_money', etc.
  fechaPago       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}